# ========================================
# Configuration Docker
# ========================================

# Mode de projet (dev ou production)
NODE_PROJET=dev

# Activer SSL (true ou false)
ENABLE_SSL=false

# URL de base de l'application (protocole + domaine + port si non-standard)
# Dev local : http://localhost:3000
# Prod      : https://rncp.theomouty.fr
APP_DOMAIN=http://localhost:3000

# Noms Traefik (doivent être uniques par environnement sur le même serveur)
TRAEFIK_ROUTER_NAME=calculatorgcc
TRAEFIK_SERVICE_NAME=calculatorgcc

# Chemins (ne pas modifier si vous utilisez Make)
BACKEND_PATH=/app
FRONTEND_PATH=/app

# ========================================
# Configuration Base de données
# ========================================

# Mot de passe root pour MariaDB (sera généré aléatoirement si non configuré)
# Générer un mot de passe fort: openssl rand -base64 32
DB_ROOT_PASSWORD=

# Nom de la base de données
DB_NAME=calculatorgcc

# Utilisateur de la base de données (non-root)
DB_USER=calculatorgcc_user

# Mot de passe de l'utilisateur (sera généré aléatoirement si non configuré)
DB_PASSWORD=

# Chemin persistant MariaDB sur l'hote
# Utilise par le volume Docker "mariadb_data" via driver_opts bind
# Important: utiliser un chemin different pour la prod et la preprod
MARIADB_DATA_PATH=/data/calculatorgcc/mariadb

# Alias reseau de cette DB sur le reseau Docker partage Coolify
# Prod: calculatorgcc-prod-db
# Preprod: calculatorgcc-preprod-db
DB_SHARED_ALIAS=calculatorgcc-prod-db

# Préprod: cloner la base de prod dans la base locale avant de démarrer le backend
CLONE_FROM_PROD_ENABLED=false
REQUIRE_CONFIGURED_DB=false
PROD_DB_HOST=
PROD_DB_PORT=3306
PROD_DB_NAME=calculatorgcc
PROD_DB_USER=
PROD_DB_PASSWORD=
