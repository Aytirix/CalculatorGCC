generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Configuration {
  id             Int      @id @default(1)
  clientId42     String   @default("") @db.Text
  clientSecret42 String   @default("") @db.Text
  setupToken     String?  @db.VarChar(128)
  isConfigured   Boolean  @default(false)
  updatedAt      DateTime @updatedAt

  @@map("configuration")
}

model UserSimulation {
  id                    Int      @id @default(autoincrement())
  userId42              Int      @unique
  login                 String   @db.VarChar(64)
  simulatedSubProjects  Json?    // Record<string, string[]>
  customProjects        Json?    // SimulatorProject[]
  manualExperiences     Json?    // ProfessionalExperience[]
  apiExpPercentages     Json?    // Record<number, number>
  calendarData          Json?    // CalendarData { placedProjects, dateRange, alternanceDays }
  updatedAt             DateTime @updatedAt
  createdAt             DateTime @default(now())

  simulatedProjects SimulatedProject[]

  @@map("user_simulation")
}

model SimulatedProject {
  id              Int      @id @default(autoincrement())
  userId42        Int
  projectId       String   @db.VarChar(128)
  percentage      Int      @default(100)
  coalitionBoost  Boolean  @default(false)
  note            String?  @db.Text
  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())

  userSimulation  UserSimulation @relation(fields: [userId42], references: [userId42], onDelete: Cascade)

  @@unique([userId42, projectId])
  @@index([projectId])
  @@map("simulated_project")
}
